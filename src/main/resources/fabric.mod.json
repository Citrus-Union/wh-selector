{
	"schemaVersion": 1,
	"id": "wh-selector",
	"version": "${version}",
	"name": "Warehouse Selector",
	"description": "Client-side helper for the Warehouse Agent: gold-axe region selection and /wh commands to push containers to the agent.",
	"authors": ["RiceCake7442"],
	"license": "MIT",
	"icon": "assets/wh-selector/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"dev.quanwup.whselector.WhSelectorClient"
		]
	},
	"depends": {
		"fabricloader": ">=$loader_version",
		"minecraft": "$minecraft_version",
		"java": ">=21",
		"fabric-api": "*"
	}
}
